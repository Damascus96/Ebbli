{
  "manifest_version": 3,
  "name": "Ebbli",
  "version": "1.0.3",
  "description": "Browser performance tool that trims ChatGPT conversation DOM to reduce lag. Privacy-first. Local-only. No servers. Ebbing away the DOM weight pulling you in.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Ebbli",
    "default_popup": "popup/popup.html"
  },
  "permissions": ["storage", "tabs", "declarativeContent"],
  "host_permissions": [
    "*://chat.openai.com/*",
    "*://chatgpt.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://chat.openai.com/*",
        "*://chatgpt.com/*"
      ],
      "js": ["dist/page-inject.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "*://chat.openai.com/*",
        "*://chatgpt.com/*"
      ],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "dist/background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["dist/page-script.js", ".dev"],
      "matches": ["*://chat.openai.com/*", "*://chatgpt.com/*"]
    }
  ]
}
